{
  "name": "aurum-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:aurum": "npm -w apps/aurum run dev",
    "build:aurum": "npm -w apps/aurum run build",
    "lint:aurum": "npm -w apps/aurum run lint",
    "test:aurum": "npm -w apps/aurum run test",
    "test:aurum:integration": "npm -w apps/aurum run test:integration",
    "test:e2e:aurum": "playwright test -c apps/aurum/playwright.config.ts",
    "test:e2e:aurum:headed": "playwright test -c apps/aurum/playwright.config.ts --headed",
    "test:e2e:aurum:report": "playwright show-report .playwright/aurum/playwright-report",
    "emulators:aurum": "node packages/e2e-harness/firebase/start-app-emulators.mjs e2e/apps/aurum.e2e.config.mjs",
    "seed:e2e:aurum": "node scripts/seed-aurum-e2e.mjs",
    "test:e2e:aurum:authenticated": "node packages/e2e-harness/firebase/run-app-e2e.mjs e2e/apps/aurum.e2e.config.mjs",
    "clean:e2e:aurum": "node packages/e2e-harness/process/clean-app-e2e.mjs e2e/apps/aurum.e2e.config.mjs",
    "emulators:midas": "node packages/e2e-harness/firebase/start-app-emulators.mjs e2e/apps/midas.e2e.config.mjs",
    "seed:e2e:midas": "node scripts/seed-midas-e2e.mjs",
    "test:e2e:midas:authenticated": "node packages/e2e-harness/firebase/run-app-e2e.mjs e2e/apps/midas.e2e.config.mjs",
    "clean:e2e:midas": "node packages/e2e-harness/process/clean-app-e2e.mjs e2e/apps/midas.e2e.config.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "firebase-tools": "^13.35.1"
  }
}
